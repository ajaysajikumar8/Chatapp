# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/chatdb

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Web Push VAPID Keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Cloudflare R2 (Media Storage)
R2_ACCOUNT_ID=your_r2_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=chat-media-bucket

# Production Resource Safeguards (active only when NODE_ENV=production)
MAX_TOTAL_USERS=50
MAX_CONCURRENT_USERS=20
MAX_FILE_SIZE_BYTES=10485760
MAX_AVATAR_SIZE_BYTES=2097152
MAX_STORAGE_PER_USER_BYTES=52428800
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,video/quicktime,video/webm,audio/mpeg,audio/mp3,audio/wav,audio/ogg,application/pdf,text/plain
TYPING_LIMIT_MS=1000
